# Copy this file to ".env" and fill in real values.
# .env is git-ignored and must never be committed.

# Port the API server listens on
PORT=4000

# Comma-separated list of origins allowed to call the API (the Vite dev server, in development)
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign JSON Web Tokens - use a long, random string in real deployments
# e.g. generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret-value

# How long an auth token stays valid
JWT_EXPIRES_IN=7d

# Name of the httpOnly cookie used to store the auth token
AUTH_COOKIE_NAME=calendar_app_token

# Directory (relative to server/) where the JSON "database" files are stored
DATA_DIR=data

# Set to "production" in real deployments
NODE_ENV=development
